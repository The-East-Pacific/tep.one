---
// Renders the latest forum topics from /data/latest-topics.json
// which is generated by .github/workflows/rss.yml
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

let items = [];
try {
  const jsonPath = path.join(__dirname, '..', '..', 'public', 'data', 'latest-topics.json');
  if (fs.existsSync(jsonPath)) {
    const data = JSON.parse(fs.readFileSync(jsonPath, 'utf-8'));
    items = (data.items || []).slice(0, 6);
  }
} catch (e) {
  // file may not exist yet on first build
}

function escapeHtml(str) {
  if (str == null) return '';
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}
---
{items.length === 0 ? (
  <p class="forum-empty">
    No recent topics yet.
    <a href="https://forum.theeastpacific.com">Visit the forum directly →</a>
  </p>
) : (
  <ul class="forum-feed">
    {items.map((item) => (
      <li>
        <a href={item.url} target="_blank" rel="noopener">
          {item.title}
        </a>
        <div class="forum-meta">
          {item.author} · {item.date}
        </div>
      </li>
    ))}
  </ul>
)}

<style>
  .forum-feed {
    list-style: none;
    background: var(--tep-dark-deep);
    border: 1px solid rgba(242, 242, 240, 0.08);
    border-radius: 14px;
    overflow: hidden;
  }
  .forum-feed li {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid rgba(242, 242, 240, 0.04);
    transition: background 0.2s;
  }
  .forum-feed li:last-child { border-bottom: none; }
  .forum-feed li:hover { background: rgba(50, 40, 48, 0.5); }
  .forum-feed a {
    color: var(--tep-light);
    font-weight: 500;
    display: block;
    margin-bottom: 0.3rem;
    line-height: 1.4;
    text-decoration: none;
  }
  .forum-feed a:hover { color: var(--tep-yellow); }
  .forum-meta {
    color: var(--tep-dim);
    font-size: 0.8rem;
  }
  .forum-empty {
    color: var(--tep-dim);
    font-style: italic;
    padding: 1rem;
  }
  .forum-empty a { color: var(--tep-yellow); }
</style>
